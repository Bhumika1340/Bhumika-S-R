{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyNouvdNMkUspKyQ4n3/wyhU"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":["def load_data(filename):\n","  \"\"\"reads crop data from a file and returns a list of dictionories\"\"\"\n","  crops=[] # Corrected 'crop' to 'crops' to match the list name\n","  file=open(filename,\"r\")\n","  for line in file:\n","    line=line.strip()\n","\n","    if line:\n","      data=line.split(\",\")\n","      crop={\n","          \"name\":data[0],\n","          \"season\":data[1],\n","          \"area\":float(data[2]),\n","          \"fertilizer\":float(data[3]), # Added missing comma\n","          \"rainfall\":float(data[4]), # Corrected typo 'floatata' to 'float'\n","          \"yield\":float(data[5]) # Corrected 'yiels' to 'yield'\n","      }\n","      crops.append(crop) # Corrected indentation\n","  file.close() # Corrected indentation\n","  return crops # Corrected indentation\n","\n","def calculate_yield_per_area(crop):\n","  \"\"\"returns yield per unit area\"\"\"\n","  return crop[\"yield\"]/crop[\"area\"]\n","\n","def display_crops(crops):\n","  \"\"\"display all crops records\"\"\"\n","  print(\"\\n crops records:\")\n","  for crop in crops:\n","    ypa=calculate_yield_per_area(crop)\n","    print(crop[\"name\"],\"_\",crop[\"season\"],\"_yield/area:\",round(ypa,2))\n","\n","\n","def find_highest_and_lowest_yield(crops):\n","  \"\"\"finds crops with highest and lowest yield\"\"\"\n","  highest=crops[0]\n","  lowest=crops[0]\n","  for crop in crops: # Corrected 'crops' to 'crop'\n","\n","    if calculate_yield_per_area(crop)>calculate_yield_per_area(highest):\n","      highest=crop\n","    if calculate_yield_per_area(crop)<calculate_yield_per_area(lowest):\n","      lowest=crop\n","  return highest,lowest # Corrected indentation for return statement\n","\n","def seasonal_summary(crops):\n","  \"\"\"generstes seasonal yield summary using dictionary\"\"\"\n","  summary={}\n","  for crop in crops:\n","    season=crop[\"season\"]\n","    ypa=calculate_yield_per_area(crop)\n","    if season not in summary:\n","      summary[season]=[] # Initialize as list if not exists\n","    summary[season].append(ypa)\n","  return summary # Corrected 'summar' to 'summary' and indentation\n","\n","def write_report(filename,crops,highest,lowest,summary):\n","  \"\"\"writes analysis results to output file\"\"\"\n","  file=open(filename,\"w\")\n","  file.write(\"Analysis results:\\n\\n\")\n","\n","  file.write(\"crop yield per unit area:\\n\")\n","  for crop in crops: # Corrected 'crops' to 'crop'\n","\n","    ypa=calculate_yield_per_area(crop) # Corrected 'calculate_yield_per_unit_area'\n","    file.write(crop[\"name\"]+\":\"+str(round(ypa,2))+\"\\n\")\n","\n","  file.write(\"\\nhighest yield:\\n\")\n","  file.write(highest[\"name\"]+\":\"+str(round(calculate_yield_per_area(highest),2))+\"\\n\") # Added content for highest yield\n","  file.write(\"\\nlowest yield:\\n\")\n","  file.write(lowest[\"name\"]+\":\"+str(round(calculate_yield_per_area(lowest),2))+\"\\n\") # Added content for lowest yield\n","\n","  file.write(\"\\nseasonal average yield:\\n\")\n","  for season in summary:\n","\n","    file.write(season+\":\"+str(round(sum(summary[season])/len(summary[season]),2))+\"\\n\")\n","  file.close()\n","\n","def main():\n","  input_file=\"crops.txt\"\n","  output_file=\"report.txt\"\n","  crops=load_data(input_file)\n","\n","  for crop_data in crops: # Changed loop variable to avoid shadowing 'crops' list\n","    print (crop_data)\n","  for crop_data in crops:\n","    for key,value in crop_data.items():\n","      print(f\"{key}:{value}\")\n","      print(\"-----\") # Corrected print statement\n","\n","  display_crops(crops)\n","  highest,lowest=find_highest_and_lowest_yield(crops)\n","  summary=seasonal_summary(crops)\n","  write_report(output_file,crops,highest,lowest,summary)\n","  print(\"\\n analysis complete.report written to\",output_file)\n","\n","\n","main() # Corrected indentation"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"SjAzWvrumzqR","executionInfo":{"status":"ok","timestamp":1768885262337,"user_tz":-330,"elapsed":198,"user":{"displayName":"Ashwini M Bhat","userId":"12361861224392479558"}},"outputId":"0d897fbb-c015-42da-aa9c-6d2b87fc3c14"},"execution_count":34,"outputs":[{"output_type":"stream","name":"stdout","text":["{'name': 'Wheat', 'season': 'Summer', 'area': 100.0, 'fertilizer': 500.0, 'rainfall': 10.0, 'yield': 2000.0}\n","{'name': 'Rice', 'season': 'Monsoon', 'area': 150.0, 'fertilizer': 800.0, 'rainfall': 15.0, 'yield': 3000.0}\n","{'name': 'Corn', 'season': 'Summer', 'area': 80.0, 'fertilizer': 400.0, 'rainfall': 8.0, 'yield': 1500.0}\n","{'name': 'Barley', 'season': 'Winter', 'area': 120.0, 'fertilizer': 300.0, 'rainfall': 12.0, 'yield': 1800.0}\n","{'name': 'Soybean', 'season': 'Monsoon', 'area': 90.0, 'fertilizer': 700.0, 'rainfall': 10.0, 'yield': 2500.0}\n","name:Wheat\n","-----\n","season:Summer\n","-----\n","area:100.0\n","-----\n","fertilizer:500.0\n","-----\n","rainfall:10.0\n","-----\n","yield:2000.0\n","-----\n","name:Rice\n","-----\n","season:Monsoon\n","-----\n","area:150.0\n","-----\n","fertilizer:800.0\n","-----\n","rainfall:15.0\n","-----\n","yield:3000.0\n","-----\n","name:Corn\n","-----\n","season:Summer\n","-----\n","area:80.0\n","-----\n","fertilizer:400.0\n","-----\n","rainfall:8.0\n","-----\n","yield:1500.0\n","-----\n","name:Barley\n","-----\n","season:Winter\n","-----\n","area:120.0\n","-----\n","fertilizer:300.0\n","-----\n","rainfall:12.0\n","-----\n","yield:1800.0\n","-----\n","name:Soybean\n","-----\n","season:Monsoon\n","-----\n","area:90.0\n","-----\n","fertilizer:700.0\n","-----\n","rainfall:10.0\n","-----\n","yield:2500.0\n","-----\n","\n"," crops records:\n","Wheat _ Summer _yield/area: 20.0\n","Rice _ Monsoon _yield/area: 20.0\n","Corn _ Summer _yield/area: 18.75\n"